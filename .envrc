dotenv_if_exists ../.env

git summary
git secrets --scan

echo
echo "snakemake --lt | xargs:"
snakemake --lt -s snakefile.smk --configfile example_config.yml | xargs
echo

echo "Writing rulegraph.svg"
# snakefile.smk was previously passed as a positional target (interpreted as
# a rule name, so Snakemake couldn't find a Snakefile at all); use -s instead.
# Output goes to repo root: unlike sibling repos, this one has no workflow/
# subdirectory (snakefile.smk and rules/ live at repo root).
# example_config.yml is required: rules/setup.smk reads config["RUN_DIR"] at
# module scope, so parsing fails without a configfile even for --rulegraph.
PYTHONHASHSEED=0 snakemake --rulegraph --forceall -s snakefile.smk --configfile example_config.yml 2>/dev/null | dot -Tsvg > rulegraph.svg